digraph Sample_Job1_1_2_detailed_pseudocode {
rankdir=LR;
fontsize=10;
fontname="Arial";
node [fontname="Arial", fontsize=10, style=filled];
edge [fontname="Arial", fontsize=8];

subgraph cluster_source {
label="Source Layer";
style=rounded;
color=grey;
ORA_Ext_Vehicle_Off_Road_Data [label="ORA_Ext_Vehicle_Off_Road_Data", shape=cylinder, fillcolor="#FFD1DC"];
}

subgraph cluster_processing {
label="Transformation Layer";
style=rounded;
color=black;
Tfm_LoadRecords [label="Tfm_LoadRecords", shape=box, fillcolor="#FFF9C4"];
}

subgraph cluster_target {
label="Target Layer";
style=rounded;
color=green;
Ora_StgVehicleOffRoad [label="Ora_StgVehicleOffRoad", shape=cylinder, fillcolor="#C8E6C9"];
Supp_VOR_Exception [label="Supp_VOR_Exception", shape=note, fillcolor="#C8E6C9"];
}
ORA_Ext_Vehicle_Off_Road_Data -> Tfm_LoadRecords;
Tfm_LoadRecords -> Supp_VOR_Exception;
}