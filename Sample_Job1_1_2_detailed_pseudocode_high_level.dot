rankdir=LR;
fontsize=10;
fontname="Arial";
node [fontname="Arial", fontsize=10, style=filled];
edge [fontname="Arial", fontsize=8];

subgraph cluster_source {
label="Source Layer";
style=rounded;
color=grey;
ORA_Ext_Vehicle_Off_Road_Data [label="ORA_Ext_Vehicle_Off_Road_Data\n(data extraction)", shape=cylinder, fillcolor="#FFD1DC"];
}

subgraph cluster_processing {
label="Transformation Layer";
style=rounded;
color=black;
Tfm_LoadRecords [label="Tfm_LoadRecords\n- transformer stage\n- If VEHICLE_SK is -99, use VEHICLE_SK from lkVehicleDim_REg\n- If SUPP_SK is -99, set DESCRIPTION to 'Unknown'\nRule Clusters: 3\nConstraints: 1\nStage Variables: 1", shape=box, fillcolor="#FFF9C4"];
}

subgraph cluster_target {
label="Target Layer";
style=rounded;
color=green;
Ora_StgVehicleOffRoad [label="Ora_StgVehicleOffRoad", shape=cylinder, fillcolor="#C8E6C9"];
