}
ORA_Ext_Vehicle_Off_Road_Data -> Tfm_LoadRecords [label="ORA_Ext_Vehicle_Off_Road_Data"];
Tfm_LoadRecords -> Supp_VOR_Exception [label="Tfm_LoadRecords"];
Note1 [shape=plaintext, label="Semantic Summary:\n- Job Type: ETL Data Integration\n- Purpose: To integrate and transform vehicle off-road data from Oracle to a sequential file.\n- Complexity Level: Medium\n- Historical Dependency: No\n- Row Expansion: No\n- Decision Depth: Moderate\n- Source Stages: 1\n- Constraint Routes: 1\n- Logic Areas: Data Transformation, Data Integration, Exception Handling", fontsize=8, fillcolor="white"];
Note2 [shape=plaintext, label="Subflows:\n- Data Extraction and Transformation\n- Data Loading", fontsize=8, fillcolor="white"];
Note3 [shape=plaintext, label="Pipelines:\n- Primary: ORA_Ext_Vehicle_Off_Road_Data -> Tfm_LoadRecords -> Supp_VOR_Exception\n- Secondary: HF_SMR_VEHICLE_DIM -> Tfm_LoadRecords -> HF_FACT_VOR_DATA -> Ora_StgVehicleOffRoad", fontsize=8, fillcolor="white"];
}